ANTHROPIC_API_KEY=sk-ant-tu-key-aca
APP_AUTH_TOKEN=cambiame-por-algo-random
TELEGRAM_BOT_TOKEN=tu-token-de-botfather
TELEGRAM_ALLOWED_CHAT_ID=tu-chat-id
TELEGRAM_WEBHOOK_SECRET=secret-random
NOTION_API_TOKEN=tu-integration-token
NOTION_WATCHED_BOARDS=["Sprint Backend","Proyectos 2026"]
ALLOWED_WORKING_DIRS=["/home/user/proyectos"]
MAX_COST_PER_SESSION_USD=5.0
MAX_COST_PER_DAY_USD=20.0
SECURITY_STRICT_MODE=true
SECURITY_NOTIFY_LEVEL=warning
# Transcripción de voz (Whisper via OpenAI)
OPENAI_API_KEY=
# Gmail — OAuth2 Bearer token para MCP de Google (gmail.googleapis.com/mcp/v1)
# Cómo obtenerlo:
#   1. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
#   2. Scopes requeridos: https://www.googleapis.com/auth/gmail.modify
#   3. O usá: npx @modelcontextprotocol/inspector  (sigue el flujo OAuth interactivo)
#   4. Copiá el access_token resultante acá (dura ~1h; usá refresh_token en prod)
GMAIL_OAUTH_TOKEN=
GMAIL_WATCHER_ENABLED=false
GMAIL_WATCHED_LABELS=["INBOX"]
# Google Calendar — mismo token OAuth2 si tiene scope calendar incluido
# Scopes: https://www.googleapis.com/auth/calendar.readonly (o .events para escribir)
CALENDAR_OAUTH_TOKEN=
CALENDAR_WATCHER_ENABLED=false
