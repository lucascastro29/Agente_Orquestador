ANTHROPIC_API_KEY=sk-ant-tu-key-aca
APP_AUTH_TOKEN=cambiame-por-algo-random
TELEGRAM_BOT_TOKEN=tu-token-de-botfather
TELEGRAM_ALLOWED_CHAT_ID=tu-chat-id
TELEGRAM_WEBHOOK_SECRET=secret-random
NOTION_API_TOKEN=tu-integration-token
NOTION_WATCHED_BOARDS=["Sprint Backend","Proyectos 2026"]
ALLOWED_WORKING_DIRS=["/home/user/proyectos"]
# Chrome agent — dominios permitidos para navegación headless
CHROME_ALLOWED_DOMAINS=["instagram.com","linkedin.com"]
MAX_COST_PER_SESSION_USD=5.0
MAX_COST_PER_DAY_USD=20.0
SECURITY_STRICT_MODE=true
SECURITY_NOTIFY_LEVEL=warning
# Transcripción de voz (Whisper via OpenAI)
OPENAI_API_KEY=
# Google OAuth2 — credenciales para Gmail, Calendar y Drive
# Cómo obtenerlas (una sola vez):
#   1. console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
#   2. Application type: Desktop app
#   3. Habilitá: Gmail API, Google Calendar API, Google Drive API
#   4. Descargá el credentials.json y corré scripts/get_google_tokens.py
#   5. Pegá los valores que imprime el script acá abajo
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Scopes usados: gmail.modify, calendar, drive
# El refresh token NO vence — el backend renueva el access token automáticamente
GMAIL_WATCHER_ENABLED=false
GMAIL_WATCHED_LABELS=["INBOX"]
CALENDAR_WATCHER_ENABLED=false
